  function computeBrandItemCounts(data){
    const counts = {};
    data.forEach(it=>{
      counts[it.marca] = (counts[it.marca]||0) + 1;
    });
    return counts;
  }
  function parseSvc(text){
    const ix = text.indexOf(':');
    if(ix===-1) return {general:text.trim(), specific:''};
    return {general:text.slice(0,ix).trim(), specific:text.slice(ix+1).trim()};
  }
  function syncToCatalog(brand, svcFull){
