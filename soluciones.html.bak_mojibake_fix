  function stopAutoplay(){
    if(!autoplayId) return;
    window.clearInterval(autoplayId);
    autoplayId = null;
  }

  function setPaused(v){
    paused = v;
    if(paused) stopAutoplay();
    else startAutoplay();
  }

  carousel.addEventListener('mouseenter', () => setPaused(true));
