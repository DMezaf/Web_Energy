  <style>
    :root{
      --navy:#172C51; /* Azul Marino */
      --cobalt:#0F4C81; /* Azul Cobalto (acentos) */
      --blue-2:#274B7C;
      --blue-3:#3A6FA5;
      --gray:#F2F4F7;
      --text:#0F172A;
      --verde-tech:#22C55E; /* acento sutil para estados */
      --danger:#EF4444;
    }
    html{scroll-behavior:smooth}
    body{margin:0;font-family:"Roboto Condensed",system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;color:var(--text);background:#ffffff;}
    /* ===== Layout ===== */
    .container{max-width:1200px;margin-inline:auto;padding:0 20px}
    header{position:sticky;top:0;z-index:40;background:#fff;border-bottom:1px solid rgba(23,44,81,.08);backdrop-filter:saturate(180%) blur(8px)}
    .topbar{display:flex;align-items:center;justify-content:space-between;padding:10px 0}
    .brand{display:flex;align-items:center;gap:0}
    .brand__logo{width:72px;height:72px;border-radius:10px;background:#fff;display:grid;place-items:center;overflow:hidden;border:1px solid rgba(23,44,81,.14)}
    .brand__logo img{max-width:96%;max-height:96%;object-fit:contain;display:block}
    .brand__name{font-weight:700;font-size:18px;color:var(--navy)}
    nav ul{list-style:none;margin:0;padding:0;display:flex;gap:20px}
    nav a{color:var(--navy);text-decoration:none;font-weight:700;letter-spacing:.2px}
    .cta-header{padding:.6rem 1rem;background:var(--cobalt);color:#fff;border-radius:999px}
    .menu-toggle{display:none;border:1px solid rgba(23,44,81,.2);border-radius:10px;padding:.5rem .7rem;background:#fff}
    .nav-item--has-submenu{position:relative}
    .submenu{
      list-style:none;
      margin:0;
      padding:10px 12px;
      position:absolute;
      top:calc(100% + 10px);
      left:0;
      min-width:320px;
      background:#fff;
      border:1px solid rgba(23,44,81,.12);
      border-radius:12px;
      box-shadow:0 14px 30px rgba(8,28,54,.12);
      display:none;
      z-index:60;
    }
    .nav-item--has-submenu:hover .submenu,
    .nav-item--has-submenu:focus-within .submenu{display:block}
    .submenu__group + .submenu__group{
      margin-top:10px;
      padding-top:10px;
      border-top:1px solid rgba(23,44,81,.1);
    }
    .submenu__title{
      display:block;
      color:#0f4c81;
      font-size:.76rem;
      font-weight:800;
      letter-spacing:.08em;
      text-transform:uppercase;
      margin:0 0 6px;
    }
    .submenu__list{
      list-style:none;
      margin:0;
      padding:0;
      display:grid;
      gap:6px;
    }
    .submenu__list a{
      display:block;
      color:#12365f;
      font-weight:600;
      font-size:.9rem;
      line-height:1.25;
      padding:3px 0;
    }
    @media (max-width:680px){
      .nav-item--has-submenu .submenu{
        position:static;
        display:block;
        min-width:0;
        border:0;
        border-radius:0;
        box-shadow:none;
        padding:8px 0 0 12px;
      }
      nav ul{display:none}
      .menu-toggle{display:inline-flex}
    }
/* ===== Hero ===== */
    .hero{position:relative;isolation:isolate;background:radial-gradient(80% 60% at 70% 20%, rgba(63,111,165,.25), transparent 60%),linear-gradient(180deg, #0a162b 0%, #0a162b 40%, #0f2244 100%);
      color:#fff;overflow:hidden}
    .hero:before{content:none}
    .hero-carousel{position:relative}
    .hero-carousel__viewport{position:relative}
    .hero-slide{display:none;animation:heroFade .45s ease;position:relative}
    .hero-slide.is-active{display:block}
    .hero-slide::after{content:"";position:absolute;inset:0;background:linear-gradient(100deg,rgba(10,22,43,.9) 0%,rgba(10,22,43,.76) 45%,rgba(10,22,43,.45) 100%),var(--hero-image) center/cover no-repeat;z-index:0}
    .hero__wrap{display:grid;grid-template-columns:1fr;gap:20px;align-items:center;padding:88px 0;min-height:520px;position:relative;z-index:1}
    .hero__content{max-width:760px}
    .eyebrow{display:inline-block;padding:.25rem .6rem;border:1px solid rgba(255,255,255,.25);border-radius:999px;font-size:.8rem;letter-spacing:.4px;margin-bottom:14px}
    .hero h1,.hero h2{font-size:clamp(28px,4.2vw,48px);line-height:1.05;margin:0 0 12px}
    .hero p{font-size:clamp(16px,2.1vw,20px);opacity:.9;margin:0 0 20px}
    .hero__ctas{display:flex;gap:12px;flex-wrap:wrap}
    .btn{display:inline-flex;align-items:center;gap:8px;border-radius:14px;padding:12px 18px;font-weight:700;text-decoration:none;border:1px solid transparent}
    .btn--primary{background:var(--cobalt);color:#fff}
    .btn--secondary{background:transparent;border-color:rgba(255,255,255,.35);color:#fff}
    .hero__image{display:none}
    .hero-carousel__nav{position:absolute;top:50%;transform:translateY(-50%);z-index:2;border:1px solid rgba(255,255,255,.28);background:rgba(10,22,43,.48);color:#fff;border-radius:999px;width:42px;height:42px;display:grid;place-items:center;cursor:pointer}
    .hero-carousel__nav:hover{background:rgba(10,22,43,.72)}
    .hero-carousel__nav--prev{left:16px}
    .hero-carousel__nav--next{right:16px}
    .hero-carousel__dots{display:flex;justify-content:center;gap:8px;padding:0 0 18px}
    .hero-carousel__dot{width:10px;height:10px;border-radius:999px;border:1px solid rgba(255,255,255,.5);background:transparent;cursor:pointer}
    .hero-carousel__dot.is-active{background:#fff}
    @keyframes heroFade{from{opacity:.2;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}

    /* ===== Trust / ISO ===== */
    .trust{background:linear-gradient(180deg,#fff,#f7f9fc)}
    .trust__grid{display:grid;grid-template-columns:repeat(5,1fr);gap:18px}
    .trust__card{border:1px solid rgba(23,44,81,.12);border-radius:14px;padding:14px;background:#fff}
    .trust__title{font-size:.9rem;color:var(--navy);margin:0}
    .trust__code{font-size:.8rem;color:#475569;margin:4px 0 0}

    .diff__badge{
      width:100%;
      max-width:100%;
      height:clamp(86px,10vw,124px);
      object-fit:contain;
      display:block;
      margin:0 0 12px;
    }
    .card{border:1px solid rgba(23,44,81,.12);border-radius:16px;padding:18px;background:#fff}
    .card h3{margin:8px 0 6px;font-size:18px;color:var(--navy)}
    .card p{margin:0;color:#475569;font-size:15px}

    /* ===== Soluciones ===== */
    .sol{background:#fff}
    .sol__grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px}
    .sol__item{position:relative;border:1px solid rgba(23,44,81,.12);border-radius:16px;overflow:hidden;background:#0a162b;color:#fff}
    .sol__img{height:140px;background:linear-gradient(180deg,rgba(15,76,129,.25),rgba(15,76,129,.6)),url('https://images.unsplash.com/photo-1509395176047-4a66953fd231?q=80&w=1400&auto=format&fit=crop') center/cover}
    .sol__body{padding:14px}
    .sol__body h3{margin:0 0 6px;font-size:18px}
    .sol__body p{margin:0 0 10px;font-size:14px;opacity:.9}

    /* ===== Servicios & Especialidades (Blueprint) ===== */
    .svc{
      position:relative;
      padding:clamp(28px,4vw,56px) 0;
      color:#eaf2ff;
      background:radial-gradient(1200px 680px at 20% 10%, rgba(58,111,165,.18), transparent 60%),
                 radial-gradient(900px 520px at 90% 20%, rgba(15,76,129,.20), transparent 55%),
                 linear-gradient(180deg, rgba(23,44,81,.85), rgba(10,22,40,.92));
      overflow:hidden;
      border-top:1px solid rgba(255,255,255,.06);
      border-bottom:1px solid rgba(255,255,255,.06);
    }
    .svc::before{content:none}
    .svc .container{position:relative;z-index:1}
    .section-intro,
    .svc__intro{
      margin:0 0 14px;
      padding:16px 18px;
      border-radius:14px;
      border:1px solid rgba(23,44,81,.14);
      background:#f7f9fc;
      box-shadow:0 10px 24px rgba(8,28,54,.06);
    }
    .svc__intro{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:16px;
    }
    .svc__intro-main{flex:1 1 auto}
    .svc__intro-cta{
      display:flex;
      align-items:center;
      justify-content:flex-end;
      text-align:right;
      flex:0 0 auto;
    }
    .section-intro--compact{
      margin-bottom:12px;
      padding:14px 16px;
    }
    .section-intro__title,
    .svc__intro h3{
      margin:0;
      color:#113960;
      font-size:clamp(1.35rem,2.1vw,2rem);
      line-height:1.08;
    }
    .section-intro__lead,
    .svc__intro p{
      margin:6px 0 0;
      color:#5b7391;
      font-size:1rem;
      line-height:1.4;
    }
    .svc__head{
      display:flex;
      align-items:center;
      justify-content:flex-start;
      gap:10px;
      margin:2px 0 12px;
      padding-left:2px;
    }
    .svc__cta .btn{
      padding:8px 14px;
      border-radius:10px;
      border:1px solid rgba(17,57,96,.28);
      background:#fff;
      color:#0F4C81;
      font-weight:700;
      box-shadow:none;
    }
    .svc__cta .btn:hover{
      background:rgba(142,215,255,.14);
      border-color:rgba(17,57,96,.45);
      transform:translateY(-1px);
    }
    .svc__kicker{margin:0 0 6px;font-size:.92rem;letter-spacing:.12em;text-transform:uppercase;color:rgba(234,242,255,.78)}
    .svc__title{margin:0;font-size:clamp(1.35rem,2.4vw,2.05rem);line-height:1.1;color:#eaf2ff}
    .svc__cta{display:flex;gap:10px}
    .svc{--svc-gap:25px}
    .svc__carousel{position:relative}
    .svc__viewport{overflow:hidden}
    .svc__grid{
      display:flex;
      gap:var(--svc-gap);
      transition:transform .35s ease;
      will-change:transform;
    }
    .svc__grid .svc__card{
      flex:0 0 calc((100% - (var(--svc-gap) * 2)) / 3);
      min-width:0;
    }
    .svc__nav{display:flex;justify-content:flex-end;gap:10px;margin:0 0 12px}
    .svc__navBtn{
      width:38px;height:38px;border-radius:999px;
      border:1px solid rgba(255,255,255,.22);
      background:rgba(255,255,255,.08);color:#eaf2ff;
      cursor:pointer;font-size:18px;line-height:1;
    }
    .svc__navBtn:disabled{opacity:.45;cursor:not-allowed}
    .svc__card{
      border-radius:18px;overflow:hidden;
      background:linear-gradient(180deg, rgba(255,255,255,.06), rgba(255,255,255,.02));
      border:1px solid rgba(255,255,255,.10);
      box-shadow:0 10px 30px rgba(0,0,0,.22);
      transition:transform .18s ease,border-color .18s ease,box-shadow .18s ease;
    }
    .svc__media{position:relative;aspect-ratio:4/3;border-bottom:1px solid rgba(255,255,255,.10)}
    .svc__media img{width:100%;height:100%;object-fit:cover;display:block;opacity:.95;filter:contrast(1.02) saturate(1.02)}
    .svc__glow{
      position:absolute;inset:-30%;
      background:radial-gradient(closest-side, rgba(110,210,255,.22), transparent 70%);
      opacity:0;transform:translate3d(-10px,10px,0);pointer-events:none;transition:opacity .18s ease,transform .18s ease;
    }
    .svc__body{padding:14px 14px 12px}
    .svc__name{margin:0 0 8px;font-size:1.02rem;letter-spacing:.01em;color:#eaf2ff}
    .svc__bullets{margin:0;padding-left:18px;color:rgba(234,242,255,.78);font-size:.94rem;line-height:1.35}
    .svc__bullets li{margin:6px 0}
    .svc__actions{margin-top:12px;display:flex;align-items:center;justify-content:flex-start;gap:12px}
    .svc__link{
      display:inline-flex;align-items:center;gap:8px;
      padding:8px 12px;
      border-radius:999px;
      border:1px solid rgba(147,230,255,.55);
      background:linear-gradient(180deg, rgba(95,197,255,.22), rgba(27,98,163,.30));
      color:#eaf7ff;
      text-decoration:none;
      font-weight:700;
      font-size:.9rem;
      letter-spacing:.01em;
      box-shadow:0 8px 20px rgba(5,16,34,.32), inset 0 0 0 1px rgba(255,255,255,.08);
      transition:transform .18s ease, box-shadow .18s ease, background .18s ease, border-color .18s ease;
    }
    .svc__link::after{
      content:"\2192";
      font-size:.95em;
      transform:translateX(0);
      transition:transform .18s ease;
    }
    .svc__link:hover{
      transform:translateY(-1px);
      border-color:rgba(187,241,255,.85);
      background:linear-gradient(180deg, rgba(113,211,255,.30), rgba(35,122,198,.38));
      box-shadow:0 12px 24px rgba(5,16,34,.4), inset 0 0 0 1px rgba(255,255,255,.12);
    }
    .svc__link:hover::after{
      transform:translateX(2px);
    }
    .svc__link:focus-visible{
      outline:2px solid rgba(214,243,255,.92);
      outline-offset:2px;
    }
    .svc__card:hover{transform:translateY(-3px);border-color:rgba(180,235,255,.26);box-shadow:0 22px 60px rgba(0,0,0,.35)}
    .svc__card:hover .svc__glow{opacity:1;transform:translate3d(0,0,0)}
    .svc__card:hover .svc__media img{opacity:1;filter:contrast(1.08) saturate(1.05)}
    .svc__note{margin-top:14px;color:rgba(234,242,255,.82)}
    @media (max-width:640px){
      .section-intro,
      .svc__intro{padding:14px}
      .svc__intro{
        flex-direction:column;
        align-items:flex-start;
      }
      .svc__intro-cta{
        width:100%;
        justify-content:flex-end;
      }
      .svc__head{align-items:flex-start;flex-direction:column}
    }

    /* ===== Suministro (marcas/procura) ===== */
    .procura{background:linear-gradient(180deg,#f7f9fc,#fff)}
    .procura__form{display:grid;grid-template-columns:repeat(4,1fr);gap:12px}
    .input, select, textarea{width:100%;padding:12px;border:1px solid rgba(23,44,81,.18);border-radius:12px;font-size:15px}
    .hint{font-size:12px;color:#64748B;margin-top:6px}

    /* ===== Testimonios (prueba social) ===== */
    .testi__grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
    .quote{background:#fff;border:1px solid rgba(23,44,81,.12);border-radius:16px;padding:18px}
    .quote p{margin:0 0 10px}
    .quote .who{font-size:14px;color:#475569}
    .foot{background:#0b1428;color:#cbd5e1}
    #footer .container{
      display:grid !important;
      grid-template-columns:1.25fr 1fr 1fr 1fr 1fr !important;
      gap:18px !important;
      padding:40px 0 !important;
      align-items:start;
    }
    #footer h4{
      margin:0 0 10px !important;
      font-size:1rem;
      line-height:1.2;
    }
    #footer ul{
      margin:0 !important;
      padding:0 !important;
      list-style:none;
      font-size:14px;
      line-height:1.7;
    }
    #footer li{
      margin:0 0 4px;
    }
    #footer a{
      word-break:break-word;
    }
    .foot-social__link{
      display:inline-flex;
      width:26px;
      height:26px;
    }
    .foot-social__link svg{
      fill:#fff;
      transition:fill .3s ease;
    }
    .foot-social__link:hover svg,
    .foot-social__link:focus-visible svg{
      fill:#0F4C81;
    }
    @media (max-width:1300px){
      #footer .container{
        grid-template-columns:repeat(3,minmax(0,1fr)) !important;
        gap:20px !important;
        padding:34px 0 !important;
      }
    }
    @media (max-width:980px){
      #footer .container{
        grid-template-columns:repeat(2,minmax(0,1fr)) !important;
      }
    }
    @media (max-width:700px){
      #footer .container{
        grid-template-columns:1fr !important;
        gap:16px !important;
        padding:24px 0 !important;
      }
      #footer ul{
        line-height:1.6;
      }
    }

    /* ===== Utilities ===== */
    section{padding:48px 0}
    .section-title{font-size:24px;color:var(--navy);margin:0 0 12px}
    .section-lead{margin:0 0 24px;color:#475569}

    /* ===== Responsive ===== */
    @media (max-width:1024px){
      .hero__wrap{grid-template-columns:1fr;min-height:500px}
      .trust__grid{grid-template-columns:repeat(3,1fr)}
      .diff__grid{grid-template-columns:repeat(2,1fr)}
      .sol__grid{grid-template-columns:repeat(2,1fr)}
      .testi__grid{grid-template-columns:1fr 1fr}
      .procura__form{grid-template-columns:1fr 1fr}
    }
    @media (max-width:680px){
      nav ul{display:none}
      .menu-toggle{display:inline-flex}
      .hero__wrap{padding:72px 0 86px;min-height:460px}
      .hero__content{max-width:100%}
      .hero-carousel__nav{width:36px;height:36px}
      .hero-carousel__nav--prev{left:8px}
      .hero-carousel__nav--next{right:8px}
      .trust__grid{grid-template-columns:1fr 1fr}
      .diff__grid,.sol__grid,.testi__grid,.procura__form{grid-template-columns:1fr}
    }
      /* ===== Accordion (Servicios) ===== */
    .accordion{margin-top:8px}
    .accordion details{border:1px solid rgba(23,44,81,.12);border-radius:14px;background:#fff;margin:10px 0;padding:12px}
    .accordion summary{cursor:pointer;font-weight:700;color:var(--navy);outline:none}
    .accordion ul{margin:8px 0 0 18px;color:#475569}
    .badge{display:inline-block;font-size:12px;padding:.1rem .5rem;border:1px solid rgba(23,44,81,.15);border-radius:999px;margin-left:8px;color:#475569}
    /* ===== Filters (Servicios) ===== */
    .filters{display:flex;gap:16px;align-items:flex-start;flex-wrap:wrap;margin:8px 0 16px}
    .filters fieldset{border:1px solid rgba(23,44,81,.12);border-radius:12px;padding:10px 12px;background:#fff}
    .filters legend{font-weight:700;color:var(--navy);font-size:14px;padding:0 6px}
    .filters label{display:inline-flex;gap:8px;align-items:center;margin-right:12px;font-size:14px;color:#475569}
    .filters input[type="checkbox"]{inline-size:16px;block-size:16px}
    .hidden{display:none !important}
      /* ===== Procura – CatÃ¡logo ===== */
    .prod-filters{display:flex;gap:12px;flex-wrap:wrap;margin:16px 0}
    .prod-filters select,.prod-filters input[type="search"]{padding:10px;border:1px solid rgba(23,44,81,.18);border-radius:10px;font-size:14px}
    .prod-accordion details{border:1px solid rgba(23,44,81,.12);border-radius:14px;background:#fff;margin:10px 0;padding:12px}
    .prod-accordion summary{cursor:pointer;font-weight:700;color:var(--navy)}
    .prod-meta{display:flex;gap:8px;flex-wrap:wrap;margin:6px 0}
    .avail{font-size:12px;border-radius:999px;padding:.1rem .5rem;border:1px solid rgba(23,44,81,.15)}
    .avail--yes{color:#065f46;background:#d1fae5;border-color:#bbf7d0}
    .avail--no{color:#7f1d1d;background:#fee2e2;border-color:#fecaca}
    /* ===== Nosotros (cards + acordeÃ³n) ===== */
    .about{background:linear-gradient(180deg,#fff,#f7f9fc)}
    .about .section-lead{max-width:900px}
    .about__grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
    .about__grid .card{min-height:100%}
    .about__accord details{border:1px solid rgba(23,44,81,.12);border-radius:14px;background:#fff;margin:10px 0;padding:12px}
    .about__accord summary{cursor:pointer;font-weight:700;color:var(--navy)}
    .about__img-placeholder{
      margin-top:12px;
      border:1px dashed rgba(23,44,81,.35);
