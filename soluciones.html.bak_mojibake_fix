  const categoryMap = {
    'petroleo-gas': ['petroleo-gas'],
    'mineria': ['mineria'],
    'alimentos-bebidas': ['alimentos-bebidas'],
    'otras-industrias': ['energia', 'electronica', 'puertos', 'pulpa-papel', 'otras-industrias']
  };

  let page = 0;
  let filteredItems = [];
  let activeCategory = '';

  const items = [];
  sectors.forEach(sec => {
    const sectorKey = sec.getAttribute('data-client-sector') || '';
    const sectorLabel = labels[sectorKey] || sectorKey;
    Array.from(sec.querySelectorAll('.logo-ph')).forEach(logo => {
      const name = (logo.querySelector('.logo-ph__name')?.textContent || '').trim();
      if(!name) return;
      const clone = logo.cloneNode(true);
      const host = clone.querySelector('.logo-ph__hint') || clone.querySelector('div > div');
      if(host){
        const tag = document.createElement('span');
        tag.className = 'logo-ph__sector';
        tag.textContent = sectorLabel;
        host.appendChild(tag);
      }
      items.push({
        sectorKey,
        sectorLabel,
        name: name.toLowerCase(),
        node: clone
      });
    });
  });

  grid.innerHTML = ''
    + '<div class="clients-carousel">'
    + '  <div class="clients-carousel__top">'
    + '    <button type="button" class="clients-carousel__btn clients-carousel__btn--prev" aria-label="Clientes anteriores">&#8249;</button>'
    + '    <span class="clients-carousel__meta">Mostrando 1-4 de 4 clientes</span>'
    + '    <button type="button" class="clients-carousel__clear" hidden>Limpiar filtros</button>'
    + '    <button type="button" class="clients-carousel__btn clients-carousel__btn--next" aria-label="Clientes siguientes">&#8250;</button>'
    + '  </div>'
    + '  <div class="clients-carousel__track"></div>'
    + '</div>';

  const track = grid.querySelector('.clients-carousel__track');
  const prevBtn = grid.querySelector('.clients-carousel__btn--prev');
  const nextBtn = grid.querySelector('.clients-carousel__btn--next');
  const meta = grid.querySelector('.clients-carousel__meta');
  const clearBtn = grid.querySelector('.clients-carousel__clear');
  if(!track || !prevBtn || !nextBtn || !meta) return;
  let autoplayTimer = null;
  let heroTimer = null;

  function countByCategory(categoryKey){
    const sectorKeys = categoryMap[categoryKey] || [];
    if(!sectorKeys.length) return 0;
    return items.filter(item => sectorKeys.includes(item.sectorKey)).length;
  }

  heroTiles.forEach(tile => {
    const key = tile.getAttribute('data-clients-category') || '';
    const count = countByCategory(key);
    let countNode = tile.querySelector('.clients-hero__tileCount');
    if(!countNode){
      countNode = document.createElement('span');
      countNode.className = 'clients-hero__tileCount';
      tile.appendChild(countNode);
    }
    countNode.textContent = count + ' clientes';
  });

  function renderPage(resetPage){
    if(resetPage) page = 0;
    const total = filteredItems.length;
    const maxPage = Math.max(0, Math.ceil(total / PAGE_SIZE) - 1);
    if(page > maxPage) page = maxPage;

    const start = page * PAGE_SIZE;
    const end = start + PAGE_SIZE;
    if(!total){
      track.innerHTML = '<div class="clients-carousel__empty">No encontramos clientes en esta categorÃ­a. Puedes limpiar filtros y volver a seleccionar.</div>';
      if(clearBtn) clearBtn.hidden = false;
    } else {
      track.innerHTML = '';
      filteredItems.slice(start, end).forEach(item => {
        track.appendChild(item.node.cloneNode(true));
      });
      if(clearBtn) clearBtn.hidden = true;
    }

    prevBtn.disabled = total <= PAGE_SIZE;
    nextBtn.disabled = total <= PAGE_SIZE;
    const from = total ? start + 1 : 0;
    const to = total ? Math.min(start + PAGE_SIZE, total) : 0;
    meta.textContent = `Mostrando ${from}-${to} de ${total} clientes`;
  }

  function applyCategoryFilter(categoryKey){
    const sectorKeys = categoryMap[categoryKey] || [];
    filteredItems = sectorKeys.length
      ? items.filter(item => sectorKeys.includes(item.sectorKey))
      : items.slice();
    renderPage(true);
  }

  function setActiveHero(categoryKey, fromUser){
    if(!categoryKey) return;
    activeCategory = categoryKey;
    heroSlides.forEach(slide => {
      const isActive = slide.getAttribute('data-clients-category') === categoryKey;
      slide.classList.toggle('is-active', isActive);
    });
    heroTiles.forEach(tile => {
      const isActive = tile.getAttribute('data-clients-category') === categoryKey;
      tile.classList.toggle('is-active', isActive);
      tile.setAttribute('aria-selected', isActive ? 'true' : 'false');
    });
    applyCategoryFilter(categoryKey);
    wrap.classList.add('is-category-selected');
    if(fromUser) restartHeroAutoplay();
  }

  function getNextCategoryKey(){
    if(!heroSlides.length || !activeCategory) return activeCategory;
    const idx = heroSlides.findIndex(s => s.getAttribute('data-clients-category') === activeCategory);
    const nextIdx = idx < 0 ? 0 : (idx + 1) % heroSlides.length;
    return heroSlides[nextIdx].getAttribute('data-clients-category') || activeCategory;
  }

  function stopHeroAutoplay(){
    if(heroTimer){
      window.clearInterval(heroTimer);
      heroTimer = null;
    }
  }

  function startHeroAutoplay(){
    if(!heroSlides.length) return;
    stopHeroAutoplay();
    heroTimer = window.setInterval(() => {
      setActiveHero(getNextCategoryKey(), false);
    }, 4600);
  }

  function restartHeroAutoplay(){
    startHeroAutoplay();
  }

  if(heroTiles.length){
    heroTiles.forEach(tile => {
      tile.addEventListener('click', () => {
        const key = tile.getAttribute('data-clients-category');
        if(!key) return;
        setActiveHero(key, true);
      });
    });
  }

  if(hero){
    hero.addEventListener('mouseenter', stopHeroAutoplay);
    hero.addEventListener('mouseleave', startHeroAutoplay);
    hero.addEventListener('focusin', stopHeroAutoplay);
    hero.addEventListener('focusout', startHeroAutoplay);
  }

  filteredItems = [];
  renderPage(true);
  if(clearBtn){
    clearBtn.addEventListener('click', () => {
      const defaultKey = heroTiles[0] ? heroTiles[0].getAttribute('data-clients-category') : '';
      if(defaultKey) setActiveHero(defaultKey, true);
    });
  }
  prevBtn.addEventListener('click', () => {
    page = Math.max(0, page - 1);
    renderPage(false);
    restartAutoplay();
  });
  nextBtn.addEventListener('click', () => {
    const maxPage = Math.max(0, Math.ceil(filteredItems.length / PAGE_SIZE) - 1);
    page = Math.min(maxPage, page + 1);
    renderPage(false);
    restartAutoplay();
  });

  function stopAutoplay(){
    if(autoplayTimer){
      window.clearInterval(autoplayTimer);
      autoplayTimer = null;
    }
  }

  function startAutoplay(){
    stopAutoplay();
    autoplayTimer = window.setInterval(() => {
      const maxPage = Math.max(0, Math.ceil(filteredItems.length / PAGE_SIZE) - 1);
      if(maxPage <= 0) return;
      page = page >= maxPage ? 0 : page + 1;
      renderPage(false);
    }, 4200);
  }

  function restartAutoplay(){
    startAutoplay();
  }

  grid.addEventListener('mouseenter', stopAutoplay);
  grid.addEventListener('mouseleave', startAutoplay);
  grid.addEventListener('focusin', stopAutoplay);
  grid.addEventListener('focusout', startAutoplay);

  startAutoplay();
})();
</script>

