    { sector:"industrial", title:"Ingenio Tamazula Variador Regenerativo 300 HP", img:"assets/img/Projects/Soluciones_industriales/Ingenio_Tamazula_Variador_Regenerativo_300_HP.png", bullets:["Variador regenerativo","Eficiencia energética","OperaciÃ³n continua"] }
