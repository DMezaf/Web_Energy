  function animateCount(el, to, ms){
    const from = Number(el.textContent.replace(/[^\d]/g,'')) || 0;
    const start = performance.now();
    const dur = clamp(ms || 700, 450, 1200);
    function tick(t){
      const p = clamp((t - start) / dur, 0, 1);
      const eased = 1 - Math.pow(1 - p, 3);
      const val = Math.round(from + (to - from) * eased);
      el.textContent = String(val);
      if(p < 1) requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);
  }

  const section = document.getElementById('cv');
  if(!section) return;
  const pills = Array.from(section.querySelectorAll('[data-count]'));
  let counted = false;

  const io = new IntersectionObserver((entries)=>{
    const entry = entries[0];
    if(!entry || !entry.isIntersecting) return;
    section.classList.add('is-inview');
    if(!counted){
      counted = true;
      pills.forEach((el, i)=>{
        const target = Number(el.getAttribute('data-count')) || 0;
        setTimeout(()=> animateCount(el, target, 720), i * 60);
      });
    }
  }, { threshold: 0.25 });
  io.observe(section);

  const nodes = section.querySelectorAll('.cvMiniTL__node');
  nodes.forEach((n)=>{
    n.addEventListener('mouseenter', ()=>{
      nodes.forEach((x)=> x.classList.add('is-dim'));
      n.classList.remove('is-dim');
      n.classList.add('is-active');
    });
    n.addEventListener('mouseleave', ()=>{
      nodes.forEach((x)=> x.classList.remove('is-dim','is-active'));
    });
    n.addEventListener('focus', ()=>{
      nodes.forEach((x)=> x.classList.add('is-dim'));
      n.classList.remove('is-dim');
      n.classList.add('is-active');
    });
    n.addEventListener('blur', ()=>{
      nodes.forEach((x)=> x.classList.remove('is-dim','is-active'));
    });
  });
})();
</script>

