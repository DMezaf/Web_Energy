        svcGen.value = gen;
        svcGen.dispatchEvent(new Event('change', {bubbles:true}));
        if(svc.specific){
          setTimeout(()=>{ svcSpec.value = svc.specific; svcSpec.dispatchEvent(new Event('change', {bubbles:true})); }, 0);
