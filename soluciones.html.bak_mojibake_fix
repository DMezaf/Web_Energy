<script>
// ==== v9.6: Resumen de filtros + abrir y resaltar detalle desde la matriz ====
(function(){
  const $ = (sel) => document.querySelector(sel);
  const $$ = (sel) => Array.from(document.querySelectorAll(sel));

  function getState(){
    return {
      brand: $('#brandFilter')?.value || '',
      product: $('#productFilter')?.value || '',
      svcGen: $('#svcGeneral')?.value || '',
      svcSpec: $('#svcEspecifico')?.value || '',
      avail: $('#availabilityFilter')?.value || '',
      q: ($('#searchModel')?.value || '').trim()
    };
  }

  function renderSummary(){
    const box = $('#activeFilters');
    if(!box) return;
    const s = getState();
    const chips = [];
    if(s.brand) chips.push(`<span class="filter-chip" data-k="brand">Marca: <strong>${s.brand}</strong> <button title="Quitar">Ã—</button></span>`);
    if(s.product) chips.push(`<span class="filter-chip" data-k="product">Procura: <strong>${s.product}</strong> <button title="Quitar">Ã—</button></span>`);
    if(s.svcGen) chips.push(`<span class="filter-chip" data-k="svcGen">Servicio: <strong>${s.svcGen}</strong> <button title="Quitar">Ã—</button></span>`);
    if(s.svcSpec) chips.push(`<span class="filter-chip" data-k="svcSpec">EspecÃ­fico: <strong>${s.svcSpec}</strong> <button title="Quitar">Ã—</button></span>`);
    if(s.avail) chips.push(`<span class="filter-chip" data-k="avail">Disponibilidad: <strong>${s.avail}</strong> <button title="Quitar">Ã—</button></span>`);
    if(s.q) chips.push(`<span class="filter-chip" data-k="q">BÃºsqueda: <strong>${s.q}</strong> <button title="Quitar">Ã—</button></span>`);
    const actions = `<span class="filters-actions">${(chips.length>0)?'<button class="btn-clear" id="btnClearAll">Limpiar todo</button>':''}</span>`;
    box.innerHTML = chips.join('') + actions;

    box.onclick = (ev)=>{
      const chip = ev.target.closest('.filter-chip');
      if(!chip) return;
      const k = chip.getAttribute('data-k');
      if(!k) return;
      switch(k){
        case 'brand': if($('#brandFilter')) { $('#brandFilter').value=''; $('#brandFilter').dispatchEvent(new Event('change', {bubbles:true})); } break;
        case 'product': if($('#productFilter')) { $('#productFilter').value=''; $('#productFilter').dispatchEvent(new Event('change', {bubbles:true})); } break;
        case 'svcGen': if($('#svcGeneral')) { $('#svcGeneral').value=''; $('#svcGeneral').dispatchEvent(new Event('change', {bubbles:true})); } if($('#svcEspecifico')) { $('#svcEspecifico').value=''; $('#svcEspecifico').dispatchEvent(new Event('change', {bubbles:true})); } break;
        case 'svcSpec': if($('#svcEspecifico')) { $('#svcEspecifico').value=''; $('#svcEspecifico').dispatchEvent(new Event('change', {bubbles:true})); } break;
        case 'avail': if($('#availabilityFilter')) { $('#availabilityFilter').value=''; $('#availabilityFilter').dispatchEvent(new Event('change', {bubbles:true})); } break;
        case 'q': if($('#searchModel')) { $('#searchModel').value=''; $('#searchModel').dispatchEvent(new Event('input', {bubbles:true})); } break;
      }
      renderSummarySoon();
    };

    const btnClearAll = $('#btnClearAll');
    if(btnClearAll){
      btnClearAll.onclick = ()=>{
        if($('#clearProdFilters')) { $('#clearProdFilters').click(); }
        else {
          if($('#brandFilter')) $('#brandFilter').value='';
          if($('#productFilter')) $('#productFilter').value='';
          if($('#svcGeneral')) $('#svcGeneral').value='';
          if($('#svcEspecifico')) $('#svcEspecifico').value='';
          if($('#availabilityFilter')) $('#availabilityFilter').value='';
          if($('#searchModel')) $('#searchModel').value='';
          ['brandFilter','productFilter','svcGeneral','svcEspecifico','availabilityFilter','searchModel'].forEach(id=>{
            const el = document.getElementById(id);
            if(!el) return;
            el.dispatchEvent(new Event((id==='searchModel')?'input':'change', {bubbles:true}));
          });
        }
        renderSummarySoon();
      };
    }
  }

  let summaryTimer;
  function renderSummarySoon(){ clearTimeout(summaryTimer); summaryTimer = setTimeout(renderSummary, 0); }

  // Hook filters changes
  ['brandFilter','productFilter','svcGeneral','svcEspecifico','availabilityFilter','searchModel','clearProdFilters'].forEach(id=>{
    const el = document.getElementById(id);
    if(!el) return;
    if(id==='searchModel') el.addEventListener('input', renderSummarySoon);
    else if(id==='clearProdFilters') el.addEventListener('click', renderSummarySoon);
    else el.addEventListener('change', renderSummarySoon);
  });

  // Open and highlight details by brand (+ optional service match)
  function openAndHighlight(brand, svcFull){
    const acc = document.getElementById('prodAccordion');
    if(!acc) return;
    setTimeout(()=>{
      const details = Array.from(acc.querySelectorAll('details'));
      let matched = 0;
      details.forEach(d=>{
        const sum = d.querySelector('summary');
        const text = (sum?.textContent || '').trim();
        const dBrand = text.split('—')[0].trim();
        const svcs = d.getAttribute('data-svcs') || '';
        const isBrand = !brand || dBrand.toLowerCase() === brand.toLowerCase();
        const isSvc = !svcFull || svcs.indexOf(svcFull) >= 0;
        if(isBrand && isSvc){
          d.open = true;
          d.classList.remove('flash-highlight');
          void d.offsetWidth; // reflow to restart animation
          d.classList.add('flash-highlight');
          matched++;
        }
      });
      // Fallback: if no match by service, highlight by brand only
      if(matched===0 && brand){
        details.forEach(d=>{
          const sum = d.querySelector('summary');
          const text = (sum?.textContent || '').trim();
          const dBrand = text.split('—')[0].trim();
          if(dBrand.toLowerCase() === brand.toLowerCase()){
            d.open = true;
            d.classList.remove('flash-highlight'); void d.offsetWidth; d.classList.add('flash-highlight');
          }
        });
      }
    }, 250); // delay to let filters render
  }

  // Listen clicks in the two matrix viewers (brand cell & service chips)
  function wireMatrixViewer(viewerSel){
    const viewer = document.querySelector(viewerSel);
    if(!viewer) return;
    viewer.addEventListener('click', (ev)=>{
      const chip = ev.target.closest('.svc-chip');
      if(chip){
        const brand = chip.getAttribute('data-brand');
        const svc = chip.getAttribute('data-svc');
        openAndHighlight(brand, svc);
        return;
      }
