<script>
(function(){
  // ===== Servicios: filters by TensiÃ³n/Norma/Tipo =====
  const tensionChecks = [...document.querySelectorAll('input[name="svc-filter"]')];
  const typeChecks = [...document.querySelectorAll('input[name="svc-type"]')];
  const feedback = document.getElementById('filterFeedback');
  const svcAccord = document.querySelector('#servicios .accordion');
  if(!feedback || !svcAccord || (!tensionChecks.length && !typeChecks.length)) return;

  function applyServiceFilters(){
    const activeT = new Set(tensionChecks.filter(c=>c.checked && ['BT','MT','AT'].includes(c.value)).map(c=>c.value));
    const activeN = new Set(tensionChecks.filter(c=>c.checked && ['NOM','UL','FM'].includes(c.value)).map(c=>c.value));
    const activeType = new Set(typeChecks.filter(c=>c.checked).map(c=>c.value));

    const details = svcAccord ? [...svcAccord.querySelectorAll('details')] : [];
    details.forEach(d=>{
      // show by type
      const dtype = d.getAttribute('data-type') || 'Servicios';
      let visible = activeType.size ? activeType.has(dtype) : true;

      // If tension/norm filters are active, also require one badge match inside list items
      if(visible && (activeT.size || activeN.size)){
        const badges = [...d.querySelectorAll('.badge')].map(b=>b.textContent.trim());
        const tMatch = !activeT.size || badges.some(b=>activeT.has(b));
        const nMatch = !activeN.size || badges.some(b=>activeN.has(b));
        visible = tMatch && nMatch;
      }
      d.classList.toggle('hidden', !visible);
    });

    const parts = [];
    if(activeT.size) parts.push('TensiÃ³n: '+[...activeT].join(', '));
    if(activeN.size) parts.push('Norma: '+[...activeN].join(', '));
    if(activeType.size) parts.push('Tipo: '+[...activeType].join(', '));
    feedback.textContent = parts.length ? ('Filtros activos ? ' + parts.join(' · ')) : 'Sin filtros activos: mostrando todo.';
  }

  tensionChecks.concat(typeChecks).forEach(c=>c.addEventListener('change', applyServiceFilters));
  applyServiceFilters();

  // ===== Procura: Servicio general/especÃ­fico dependent selects =====
  const svcGeneral = document.getElementById('svcGeneral');
  const svcEspecifico = document.getElementById('svcEspecifico');

  const specificByGeneral = {
    'Suministro': ['Transformadores','Tableros BT/MT','Variadores de frecuencia','Luminarias LED','Cables de potencia','InstrumentaciÃ³n y actuadores'],
    'Mantenimiento': ['Predictivo (vibraciones/termografÃ­a)','Correctivo','Pruebas elÃ©ctricas primarios','Relevadores de protecciÃ³n'],
    'IngenierÃ­a': ['Diseño de subestaciones','SCADA/SDMC','Calidad de energÃ­a','Estudios de cortocircuito'],
    'CapacitaciÃ³n': ['Seguridad elÃ©ctrica','OperaciÃ³n de subestaciones','SCADA bÃ¡sico','Iluminación industrial']
  };

  function populateSpecific(){
    const g = svcGeneral.value;
    svcEspecifico.innerHTML = '<option value="">Todos</option>';
    if(!g){ svcEspecifico.disabled = true; return; }
    specificByGeneral[g].forEach(opt=>{
      const o = document.createElement('option'); o.value = opt; o.textContent = opt; svcEspecifico.appendChild(o);
    });
    svcEspecifico.disabled = false;
  }
  if(svcGeneral){ svcGeneral.addEventListener('change', populateSpecific); populateSpecific(); }

  // Optional: hook into product list filtering if product cards exist with data attributes
  function filterProducts(){
    const g = svcGeneral ? svcGeneral.value : '';
    const s = svcEspecifico ? svcEspecifico.value : '';
    document.querySelectorAll('.prod-accordion details').forEach(d=>{
      const meta = (d.getAttribute('data-svcs') || '').split('|'); // e.g., "Suministro:Transformadores|IngenierÃ­a:SCADA"
      let show = true;
      if(g){ show = meta.some(m => m.trim().startsWith(g+':')); }
      if(show && g && s){ show = meta.some(m => m.trim() === (g+':'+s)); }
      d.classList.toggle('hidden', !show);
    });
  }
  if(svcGeneral && svcEspecifico){
    svcGeneral.addEventListener('change', filterProducts);
    svcEspecifico.addEventListener('change', filterProducts);
  }

})();
</script>

