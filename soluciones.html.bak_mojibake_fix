    "Schneider": { producto: ["Tableros","Variadores"], servicios: ["IngenierÃ­a:Diseño de tableros","Suministro:Variadores de frecuencia"] },
    "Siemens": { producto: ["Tableros","MCC"], servicios: ["IngenierÃ­a:Diseño de tableros","Suministro:Centro de control de motor"] },
    "Triol": { producto: ["Variadores AT24","Variadores AT27"], servicios: ["Suministro:Variadores de frecuencia","Mantenimiento:Correctivo"] },
    "Basler": { producto: ["Reguladores"], servicios: ["IngenierÃ­a:Protecciones y coordinaciÃ³n"] },
    "Deif": { producto: ["Gobernadores"], servicios: ["IngenierÃ­a:Control de velocidad","Mantenimiento:RevisiÃ³n de gobernadores"] },
    "Woodward": { producto: ["Controladores"], servicios: ["IngenierÃ­a:SincronizaciÃ³n","Mantenimiento:Correctivo"] },
    "KEI": { producto: ["Cables elÃ©ctricos"], servicios: ["Suministro:Cables de potencia"] },
    "Prysmian": { producto: ["Cables elÃ©ctricos"], servicios: ["Suministro:Cables de potencia"] },
    "Condumex": { producto: ["Cables elÃ©ctricos"], servicios: ["Suministro:Cables de potencia"] },
    "Philips": { producto: ["Iluminación"], servicios: ["Suministro:Iluminación industrial","Mantenimiento:Correctivo"] },
    "Signify": { producto: ["Iluminación"], servicios: ["Suministro:Iluminación industrial"] },
    "Osram": { producto: ["Iluminación"], servicios: ["Suministro:Iluminación industrial"] },
    "VMS Energy": { producto: ["CapacitaciÃ³n y entrenamiento"], servicios: ["CapacitaciÃ³n:Seguridad elÃ©ctrica","CapacitaciÃ³n:SCADA bÃ¡sico","CapacitaciÃ³n:OperaciÃ³n de subestaciones"] }
  };
  function wireAuditBlock(btnId, viewerId, searchWrapId, inputId){
    const btn = document.getElementById(btnId);
