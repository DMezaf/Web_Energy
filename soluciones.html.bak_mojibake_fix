<script>
(async function(){
  // Attempt to fetch from assets/data first; if not available, fall back to inline JSON
  async function loadJSON(url, inlineId){
    try {
      const r = await fetch(url, {cache:'no-store'});
      if(r.ok) return await r.json();
    } catch(e) { /* fallback */ }
    const el = document.getElementById(inlineId);
    if(el) return JSON.parse(el.textContent);
    return null;
  }

  const data = await loadJSON('assets/data/vms_supply_catalog.json', 'vms-supply-json');
  const flat = await loadJSON('assets/data/vms_supply_catalog_flat.json', 'vms-supply-json-flat');

  const $supply = document.getElementById('supplyType');
  const $cat    = document.getElementById('category');
  const $brand  = document.getElementById('brand');
  const $family = document.getElementById('family');
  const $desc   = document.getElementById('description');
  const $model  = document.getElementById('model');

  if(!($supply && $cat && $brand && $family && $desc && $model && data)) {
    console.warn('Supply wiring: elementos o datos no disponibles.');
    return;
  }

  const setOpts = (select, items, placeholder='Seleccionaâ€¦')=>{
    select.innerHTML = '';
    const opt0 = document.createElement('option');
    opt0.value = '';
    opt0.textContent = placeholder;
    select.appendChild(opt0);
    (items||[]).forEach(v=>{
      const o = document.createElement('option');
      o.value = o.textContent = v;
      select.appendChild(o);
    });
    select.disabled = !items || items.length === 0;
    // Disparar cambio para actualizar el resumen
    const evt = new Event('change', { bubbles: true });
    select.dispatchEvent(evt);
  };

  // Nivel 1
  setOpts($supply, Object.keys(data), 'Seleccionaâ€¦');
  [$cat,$brand,$family,$desc,$model].forEach(s=> s.disabled = true);

  $supply.addEventListener('change', e=>{
    const s = e.target.value;
    const cats = s ? Object.keys(data[s]||{}) : [];
    setOpts($cat, cats);
    [$brand,$family,$desc,$model].forEach(sel=> setOpts(sel, []));
  });

  $cat.addEventListener('change', e=>{
    const s = $supply.value; const c = e.target.value;
    const brands = s && c ? Object.keys((data[s]||{})[c]||{}) : [];
    setOpts($brand, brands);
    [$family,$desc,$model].forEach(sel=> setOpts(sel, []));
  });

  $brand.addEventListener('change', e=>{
    const s = $supply.value; const c = $cat.value; const b = e.target.value;
    const fams = (data[s]&&data[s][c]&&data[s][c][b]) ? Object.keys(data[s][c][b]) : [];
    setOpts($family, fams);
    [$desc,$model].forEach(sel=> setOpts(sel, []));
  });

  $family.addEventListener('change', e=>{
    const s = $supply.value; const c = $cat.value; const b = $brand.value; const f = e.target.value;
    const descs = (data[s]&&data[s][c]&&data[s][c][b]&&data[s][c][b][f]) ? Object.keys(data[s][c][b][f]) : [];
    setOpts($desc, descs);
    setOpts($model, []);
  });

  $desc.addEventListener('change', e=>{
    const s = $supply.value; const c = $cat.value; const b = $brand.value; const f = $family.value; const d = e.target.value;
    const models = (data[s]&&data[s][c]&&data[s][c][b]&&data[s][c][b][f]&&data[s][c][b][f][d]) ? data[s][c][b][f][d] : [];
    setOpts($model, models);
  });

  // (Opcional) BÃºsqueda rÃ¡pida por modelo: expone funciÃ³n global
  window.findSupplyByModel = function(q) {
    q = (q||'').toUpperCase();
    if(!flat || !q) return [];
    return flat.filter(x => (String(x.Modelo||'').toUpperCase().includes(q)));
  };
})();
</script>
