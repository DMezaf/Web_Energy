      tr.innerHTML =
        '<td><strong>'+marca+'</strong> <span class="tag" title="Ãtems detectados en catÃ¡logo">'+brandCount+' Ã­tems</span></td>' +
        '<td>'+ (data.producto||[]).join(', ') +'</td>' +
        '<td>'+ svcChips +'</td>' +
        '<td>'+ uens +'</td>';
      tr.querySelector('td').addEventListener('click', ()=>{ syncToCatalog(marca, ''); });
