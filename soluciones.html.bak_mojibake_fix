<script>
(function(){
  function initHeroCarousel(){
    const root = document.getElementById('heroCarousel');
    if(!root) return;
    const slides = Array.from(root.querySelectorAll('[data-hero-slide]'));
    const prev = root.querySelector('.hero-carousel__nav--prev');
    const next = root.querySelector('.hero-carousel__nav--next');
    const dotsWrap = document.getElementById('heroCarouselDots');
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    let current = Math.max(0, slides.findIndex(s => s.classList.contains('is-active')));
    let timer = null;

    if(!slides.length || !dotsWrap) return;

    function indexByHash(hash){
      if(!hash) return -1;
      return slides.findIndex(s => s.id === hash.replace('#',''));
    }

    function syncHash(){
      const id = slides[current]?.id;
      if(!id) return;
      if(window.location.hash !== '#' + id){
        history.replaceState(null, '', '#' + id);
      }
    }

    function setSlide(index, shouldSyncHash){
      current = (index + slides.length) % slides.length;
      slides.forEach((slide, i) => slide.classList.toggle('is-active', i === current));
      Array.from(dotsWrap.children).forEach((dot, i) => dot.classList.toggle('is-active', i === current));
      if(shouldSyncHash !== false) syncHash();
    }

    function startAutoplay(){
      if(reduceMotion) return;
      stopAutoplay();
      timer = window.setInterval(() => setSlide(current + 1, false), 6000);
    }

    function stopAutoplay(){
      if(timer){
        window.clearInterval(timer);
        timer = null;
      }
    }

    dotsWrap.innerHTML = '';
    slides.forEach((_, i) => {
      const dot = document.createElement('button');
      dot.type = 'button';
      dot.className = 'hero-carousel__dot';
      dot.setAttribute('aria-label', 'Ir al slide ' + (i + 1));
      dot.addEventListener('click', () => {
        setSlide(i, true);
        startAutoplay();
      });
      dotsWrap.appendChild(dot);
    });

    prev?.addEventListener('click', () => {
      setSlide(current - 1, true);
      startAutoplay();
    });
    next?.addEventListener('click', () => {
      setSlide(current + 1, true);
      startAutoplay();
    });

    root.addEventListener('mouseenter', stopAutoplay);
    root.addEventListener('mouseleave', startAutoplay);
    root.addEventListener('focusin', stopAutoplay);
    root.addEventListener('focusout', startAutoplay);

    const hashIndex = indexByHash(window.location.hash);
    if(hashIndex > -1) current = hashIndex;

    window.addEventListener('hashchange', () => {
      const idx = indexByHash(window.location.hash);
      if(idx > -1) setSlide(idx, false);
    });

    setSlide(current, true);
    startAutoplay();
  }

  document.addEventListener('DOMContentLoaded', initHeroCarousel);
})();
</script>

