<script>
(function(){
  const btn = document.getElementById('menuToggle');
  const list = document.getElementById('menuList');
  if(!btn || !list) return;

  function lockScroll(on){ document.documentElement.style.overflow = on ? 'hidden' : ''; }
  function closeMenu(){
    btn.setAttribute('aria-expanded','false');
    list.setAttribute('aria-expanded','false');
    list.style.display = '';
    lockScroll(false);
  }

  btn.addEventListener('click', () => {
    const open = btn.getAttribute('aria-expanded') === 'true';
    if(open){ closeMenu(); } else {
      btn.setAttribute('aria-expanded','true');
      list.setAttribute('aria-expanded','true');
      list.style.display = 'flex';
      lockScroll(true);
    }
  });

  list.querySelectorAll('a[href^="#"]').forEach(a=>{
    a.addEventListener('click', closeMenu);
  });

  document.addEventListener('keydown', (e)=>{ if(e.key==='Escape') closeMenu(); });
})();
</script>



<script id="v10-compact-logic">
(function(){
  const $ = s => document.querySelector(s);
  const $$ = s => Array.from(document.querySelectorAll(s));

  // ---- AUTO-ADVANCE in Suministro form ----
  const order = ['#supplyType','#category','#brand','#family','#description','#model'];
  function focusNext(id){
    const idx = order.indexOf('#'+id);
    if(idx>-1 && order[idx+1]) $(order[idx+1])?.focus();
  }
  document.addEventListener('change', e=>{
    if(order.includes('#'+(e.target?.id||''))) focusNext(e.target.id);
    updateQuickbar();
  });

  // ---- QUICK-PICKS (Industria) from services JSON ----
  function uniq(a){ return Array.from(new Set(a)).filter(Boolean).sort((a,b)=>a.localeCompare(b)); }
  function loadSvc(){
    try{ const el = $('#svc-json'); return el ? JSON.parse(el.textContent) : []; } catch(e){ return []; }
  }
  function ensureQuickIndustryChips(){
    const data = loadSvc();
    if(!data.length) return;
    const top = uniq(data.flatMap(x=>x.industrias||[])).slice(0,6);
    // create toolbar under catalog filters legend
    const host = document.getElementById('catIndustryField');
    if(!host || host.querySelector('.inline-toolbar')) return;
    const bar = document.createElement('div');
    bar.className = 'inline-toolbar';
    bar.innerHTML = '<span class="muted">Atajos:</span>';
    top.forEach(ind=>{
      const b = document.createElement('button');
      b.type='button'; b.className='btn btn--secondary'; b.textContent=ind;
      b.addEventListener('click',()=>{
        // toggle matching checkbox
        const cb = $('#catIndustryChecks input[value="'+ind.replace(/"/g,'&quot;')+'"]') ||
                   $$('#catIndustryChecks input').find(x=>x.nextSibling?.textContent===ind);
        if(cb){ cb.checked = !cb.checked; cb.dispatchEvent(new Event('change',{bubbles:true})); }
        // mirror into Servicios filters if present
        const svcSel = $('#svcIndustry'); if(svcSel){ svcSel.value = ind; svcSel.dispatchEvent(new Event('change',{bubbles:true})); }
        // persist
        try{ localStorage.setItem('svcSelectedIndustries', JSON.stringify(getSelectedIndustries())); }catch(e){}
        updateQuickbar();
      });
      bar.appendChild(b);
    });
    host.appendChild(bar);
  }

  // helpers
  function getSelectedIndustries(){
    return $$('#catIndustryChecks input[type="checkbox"]:checked').map(i=>i.value);
  }

  // ---- QUICKBAR SUMMARY SYNC ----
  function textOf(sel){ const el = $(sel); return (el && el.value) ? el.value : '—'; }
  function updateQuickbar(){
    const uen = textOf('#svcUEN');
    // Industries: prefer selected checkboxes, else dropdown value from Servicios, else fallback from storage
    let inds = getSelectedIndustries();
    if(!inds.length){ const v = $('#svcIndustry')?.value; if(v) inds=[v]; }
    if(!inds.length){ try{ inds = JSON.parse(localStorage.getItem('svcSelectedIndustries')||'[]'); }catch(e){} }
    const svc = '—'; // could infer from selected card later
    const sum = textOf('#supplyType');
    const marca = textOf('#brand');
    const modelo = textOf('#model');
    const chips = [
      'UEN: ' + (uen||'—'),
      'Industria: ' + (inds.length? inds.slice(0,2).join(', ') + (inds.length>2? ' +' + (inds.length-2):'') : '—'),
      'Servicio: ' + svc,
      'Suministro: ' + sum,
      'Marca: ' + marca,
      'Modelo: ' + modelo
    ];
    const box = $('#quickSummary');
    if(box){
      box.innerHTML = '';
      chips.forEach(c=>{
        const span = document.createElement('span'); span.className='chip'; span.textContent=c; box.appendChild(span);
      });
    }
  }

  // ---- KEYBOARD SHORTCUTS ----
  document.addEventListener('keydown', e=>{
    if(e.target && ['INPUT','SELECT','TEXTAREA'].includes(e.target.tagName)) return;
    if(e.key.toLowerCase()==='f'){ e.preventDefault(); $('#svcUEN')?.focus(); }
    if(e.key.toLowerCase()==='c'){ e.preventDefault(); location.hash = '#footer'; }
  });

  // ---- INITIALIZE ----
  document.addEventListener('DOMContentLoaded', function(){
    ensureQuickIndustryChips();
    updateQuickbar();
  });
})();
</script>


